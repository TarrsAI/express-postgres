# Postgres connection. Tarrs sandbox auto-injects DATABASE_URL pointing
# at the local Postgres sidecar. For local dev, point at your own
# instance (e.g. postgres://user:pass@localhost:5432/dev).
DATABASE_URL=

# Set to "1" when DATABASE_URL targets a managed Postgres provider
# (RDS / Neon / Supabase) that requires TLS. Leave unset for the
# sandbox-local Postgres sidecar (plain TCP).
DATABASE_SSL=

# JWT signing secret. MUST be ≥ 32 chars in production. Generate with:
#   openssl rand -base64 48
# Tarrs sandbox auto-generates and injects one per project.
JWT_SECRET=

# CORS — comma-separated origins (e.g. https://yourapp.vercel.app).
# Cookie auth requires CORS allow-credentials, which forbids '*'. Be
# explicit and list every frontend origin that should be able to call
# this API.
CORS_ORIGINS=

# CSRF allowed origins. If unset, the CSRF middleware reuses
# CORS_ORIGINS (same allowlist works for both 9/10 times). Set
# separately only when you want a tighter origin list for state-
# mutating requests than for cross-origin reads.
CSRF_ALLOWED_ORIGINS=

# Cookie scope. Defaults work for same-origin / subdomain.
#   COOKIE_SAMESITE=lax     same-site or via shared eTLD+1
#   COOKIE_SAMESITE=none    cross-site (frontend on Vercel, API on
#                           Tarrs sandbox) — REQUIRES https + secure.
COOKIE_SAMESITE=lax
# COOKIE_DOMAIN is left unset by default so the cookie is bound to
# the API host only. Set to ".example.com" to share across subdomains.
COOKIE_DOMAIN=

# Trust proxy hop count. 1 = behind one ALB / Caddy (Tarrs default);
# 2 = behind CloudFront + ALB; etc. Required for correct req.ip +
# X-Forwarded-For handling.
TRUST_PROXY=1

PORT=4000
LOG_LEVEL=info
NODE_ENV=development
